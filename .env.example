# Copy to .env for local development. In production the VPS sets real
# environment variables instead (e.g. systemd EnvironmentFile=) — no .env
# file should exist there.

# Static bearer token the ESP32 must send as "Authorization: Bearer <token>".
# Generate a random one, e.g.: openssl rand -hex 32
AUTH_TOKEN=change-me

# Port the HTTP server listens on. Optional, defaults to 8080.
PORT=8080

# Path to the credentials file used to read the reference calendar.
# Generated once via `go run ./cmd/oauthsetup` (see README's "Google
# Calendar setup" section) — an authorized_user-format file from a
# one-time OAuth login with your own Google account, not a service
# account key (personal GCP projects can't create those, see README).
GOOGLE_CREDENTIALS_FILE=secrets/credentials.json

# ID of the reference calendar to read events from — printed by
# cmd/oauthsetup after login. Either "primary" (your main calendar) or a
# secondary calendar's id (an email address or a
# xxx@group.calendar.google.com id).
CALENDAR_ID=your-calendar-id@group.calendar.google.com

# API key used only by `go run ./cmd/oauthsetup` (never by the server at
# runtime) to authorize the Google Picker widget that lets you pick the
# reference spreadsheet. Create it in Google Cloud Console under APIs &
# Services -> Credentials -> Create credentials -> API key, restricted to
# the Picker API (no HTTP referrer restriction needed — it's only used
# from a page served on localhost during setup). See README's "Google
# Sheets setup" section.
GOOGLE_PICKER_API_KEY=your-picker-api-key

# ID of the spreadsheet to read the shopping list from — printed by
# `go run ./cmd/oauthsetup` after you pick it in the Google Picker widget
# (should match the long string in the sheet's URL:
# https://docs.google.com/spreadsheets/d/<THIS>/edit). Read from the
# sheet's first tab, one product per row starting at row 2 (row 1 is a
# header for your own use, ignored by the server). See README's "Google
# Sheets setup" section.
GOOGLE_SHEET_ID=your-spreadsheet-id

# Timezone used to compute "today" and to format event times.
TZ=Europe/Madrid
